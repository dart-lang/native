{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Build Output Schema",
    "allOf": [
        {
            "$ref": "../../../hook/lib/schema/build_output.schema.json"
        },
        {
            "$ref": "hook_output.schema.json#"
        },
        {
            "$ref": "shared_definitions.schema.json#"
        }
    ],
    "properties": {
        "assetsForLinking": {
            "type": "object",
            "additionalProperties": {
                "type": "array",
                "items": {
                    "$ref": "shared_definitions.schema.json#/$defs/Asset"
                }
            }
        },
        "assets_for_linking": {
            "type": "object",
            "additionalProperties": {
                "type": "array",
                "items": {
                    "$ref": "shared_definitions.schema.json#/$defs/Asset"
                }
            }
        }
    },
    "_versionSkew": {
        "assets_for_linking": "Older hooks will only output 'assetsForLinking'. Older SDKs will only read 'assetsForLinking'. Newer hooks will output both, newer SDKs will read both."
    }
}
